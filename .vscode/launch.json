{
  "version": "0.2.0",
  "configurations": [
    

    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [
        "-g",
        "watermelon.cpp", 
        "-o",
        "watermelon.exe"
      ],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "d:/Desktop/PS",
      "program": "d:/Desktop/PS/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}